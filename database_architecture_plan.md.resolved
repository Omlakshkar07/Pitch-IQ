## 4. Complete Schema Definition

```sql
-- ============================================================
-- EXTENSIONS
-- ============================================================
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pg_trgm";  -- for full-text LIKE search on filenames

-- ============================================================
-- ENUMS
-- ============================================================
CREATE TYPE deck_status AS ENUM ('pending', 'analyzing', 'completed', 'failed');
CREATE TYPE flag_color AS ENUM ('red', 'amber', 'green');
CREATE TYPE readiness_level AS ENUM ('Ready', 'Nearly Ready', 'Not Ready');
CREATE TYPE confidence_level AS ENUM ('High', 'Medium', 'Low');
CREATE TYPE improvement_priority AS ENUM ('high', 'medium', 'low');
CREATE TYPE next_step_impact AS ENUM ('high', 'medium', 'low');

-- ============================================================
-- USERS
-- ============================================================
CREATE TABLE users (
    id                       UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    firebase_uid             TEXT NOT NULL UNIQUE,
    email                    TEXT NOT NULL UNIQUE,
    name                     TEXT NOT NULL,
    has_completed_onboarding BOOLEAN NOT NULL DEFAULT FALSE,
    created_at               TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at               TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    deleted_at               TIMESTAMPTZ          -- soft delete
);

-- ============================================================
-- STARTUP PROFILES (1:1 with users, created at onboarding)
-- ============================================================
CREATE TABLE startup_profiles (
    id           UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id      UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    startup_name TEXT NOT NULL CHECK (char_length(startup_name) <= 200),
    description  TEXT          CHECK (char_length(description) <= 500),
    sector       TEXT NOT NULL,
    stage        TEXT NOT NULL,
    location     TEXT NOT NULL,
    team_size    INT           CHECK (team_size > 0 AND team_size < 100000),
    website      TEXT,
    created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    UNIQUE (user_id)          -- enforces 1:1
);

-- ============================================================
-- DECKS
-- ============================================================
CREATE TABLE decks (
    id                    UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id               UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    filename              TEXT NOT NULL,
    file_size_bytes       BIGINT NOT NULL CHECK (file_size_bytes > 0 AND file_size_bytes <= 52428800), -- 50MB
    storage_url           TEXT NOT NULL,   -- S3/R2 object key
    mime_type             TEXT NOT NULL CHECK (mime_type IN (
                              'application/pdf',
                              'application/vnd.ms-powerpoint',
                              'application/vnd.openxmlformats-officedocument.presentationml.presentation'
                          )),
    status                deck_status NOT NULL DEFAULT 'pending',
    -- Startup metadata at time of upload (snapshot; user profile may change)
    sector                TEXT,
    stage                 TEXT,
    revenue_inr           NUMERIC(18,2),
    team_size             INT CHECK (team_size > 0),
    founding_year         SMALLINT CHECK (founding_year >= 1900 AND founding_year <= EXTRACT(YEAR FROM NOW())),
    location              TEXT,
    incorporation_status  TEXT,
    fundraising_status    TEXT,
    fund_raised           BOOLEAN NOT NULL DEFAULT FALSE,
    founder_name          TEXT,
    founder_email         TEXT,
    founder_phone         TEXT,
    analysis_mode         TEXT,
    uploaded_at           TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at            TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    deleted_at            TIMESTAMPTZ          -- soft delete; preserves analysis linkage
);

-- ============================================================
-- DECK ANALYSES (immutable once created)
-- ============================================================
CREATE TABLE deck_analyses (
    id                    UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    deck_id               UUID NOT NULL REFERENCES decks(id) ON DELETE RESTRICT,
    -- Restrict delete: cannot delete a deck that has an analysis without deleting analysis first
    external_analysis_id  TEXT UNIQUE,       -- analysis_id returned by AI backend
    overall_score         SMALLINT NOT NULL CHECK (overall_score BETWEEN 0 AND 100),
    idea_score            SMALLINT NOT NULL CHECK (idea_score BETWEEN 0 AND 100),
    team_score            SMALLINT NOT NULL CHECK (team_score BETWEEN 0 AND 100),
    market_score          SMALLINT NOT NULL CHECK (market_score BETWEEN 0 AND 100),
    traction_score        SMALLINT NOT NULL CHECK (traction_score BETWEEN 0 AND 100),
    risk_score            SMALLINT NOT NULL CHECK (risk_score BETWEEN 0 AND 100),
    scalability_score     SMALLINT NOT NULL CHECK (scalability_score BETWEEN 0 AND 100),
    percentile            SMALLINT          CHECK (percentile BETWEEN 0 AND 100),
    -- Narrative & structured output stored as JSONB (semi-structured, varies by analysis)
    feedback              JSONB NOT NULL DEFAULT '{}',
    -- e.g. {"idea":"...", "team":"...", "market":"...", "traction":"...", "risk":"...", "scalability":"..."}
    feedback_gaps         JSONB NOT NULL DEFAULT '{}',
    flags                 JSONB NOT NULL DEFAULT '{}',
    -- e.g. {"idea":"green","team":"amber","market":"red",...}
    risk_flags            JSONB NOT NULL DEFAULT '{}',
    -- e.g. {"red":[{"description":"...","mitigation":"..."}], "amber":[...], "green":[...]}
    team_members          JSONB NOT NULL DEFAULT '[]',
    -- e.g. [{"name":"...","role":"...","education":"...","experience":["..."]}]
    team_expertise        TEXT[] NOT NULL DEFAULT '{}',
    team_gaps             TEXT[] NOT NULL DEFAULT '{}',
    traction_metrics      JSONB NOT NULL DEFAULT '{}',
    -- e.g. {"revenue":"₹12L ARR","growthRate":"5x","capitalRaised":"$500K","revenueStatus":"amber",...}
    traction_indicators   TEXT[] NOT NULL DEFAULT '{}',
    traction_missing      TEXT[] NOT NULL DEFAULT '{}',
    business_model        TEXT,
    business_model_traits TEXT[] NOT NULL DEFAULT '{}',
    market_problem        TEXT,
    market_solution       TEXT,
    improvement_items     JSONB NOT NULL DEFAULT '[]',
    -- e.g. [{"title":"...","priority":"high","impact":"...","effort":"...","steps":["..."]}]
    improvements          TEXT[] NOT NULL DEFAULT '{}',
    strengths             TEXT[] NOT NULL DEFAULT '{}',
    critical_gaps         TEXT[] NOT NULL DEFAULT '{}',
    quick_wins            TEXT[] NOT NULL DEFAULT '{}',
    next_steps            JSONB NOT NULL DEFAULT '[]',
    -- e.g. [{"action":"...","impact":"high"}]
    analyzed_at           TIMESTAMPTZ NOT NULL,
    created_at            TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    UNIQUE (deck_id)   -- one analysis per deck
);

-- ============================================================
-- INVESTMENT READINESS RESULTS
-- ============================================================
CREATE TABLE investment_readiness_results (
    id                        UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id                   UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    analysis_id               UUID REFERENCES deck_analyses(id) ON DELETE SET NULL,
    -- Scores
    overall_score             SMALLINT NOT NULL CHECK (overall_score BETWEEN 0 AND 100),
    readiness_level           readiness_level NOT NULL,
    pitch_deck_quality_score  SMALLINT CHECK (pitch_deck_quality_score BETWEEN 0 AND 100),
    traction_metrics_score    SMALLINT CHECK (traction_metrics_score BETWEEN 0 AND 100),
    team_strength_score       SMALLINT CHECK (team_strength_score BETWEEN 0 AND 100),
    market_timing_score       SMALLINT CHECK (market_timing_score BETWEEN 0 AND 100),
    financial_health_score    SMALLINT CHECK (financial_health_score BETWEEN 0 AND 100),
    -- Guidance
    key_improvements          TEXT[] NOT NULL DEFAULT '{}',
    next_steps                TEXT[] NOT NULL DEFAULT '{}',
    estimated_time_to_ready   TEXT,
    -- Input snapshot (denormalized for auditing)
    monthly_revenue_inr       NUMERIC(18,2),
    arr_inr                   NUMERIC(18,2),
    customer_count            INT CHECK (customer_count >= 0),
    revenue_growth_rate_pct   NUMERIC(7,2),
    team_size                 INT CHECK (team_size > 0),
    runway_months             SMALLINT CHECK (runway_months >= 0),
    burn_rate_inr             NUMERIC(18,2),
    sector                    TEXT,
    stage                     TEXT,
    has_lead_investor         BOOLEAN,
    calculated_at             TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- ============================================================
-- VALUATION RESULTS
-- ============================================================
CREATE TABLE valuation_results (
    id                       UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id                  UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    -- Output
    sector                   TEXT NOT NULL,
    stage                    TEXT NOT NULL,
    valuation_low_cr         NUMERIC(18,2) NOT NULL,   -- crore INR
    valuation_median_cr      NUMERIC(18,2) NOT NULL,
    valuation_high_cr        NUMERIC(18,2) NOT NULL,
    currency                 TEXT NOT NULL DEFAULT 'INR',
    confidence_level         confidence_level NOT NULL,
    methodology              TEXT,
    revenue_multiple         NUMERIC(8,2),
    comparable_companies     JSONB NOT NULL DEFAULT '[]',
    -- e.g. [{"name":"...","valuation":"...","stage":"...","sector":"..."}]
    key_factors              TEXT[] NOT NULL DEFAULT '{}',
    valuation_tips           TEXT[] NOT NULL DEFAULT '{}',
    disclaimer               TEXT,
    -- Input snapshot
    revenue_inr              NUMERIC(18,2),
    arr_inr                  NUMERIC(18,2),
    mrr_inr                  NUMERIC(18,2),
    revenue_growth_rate_pct  NUMERIC(7,2),
    customer_count           INT,
    customer_growth_rate_pct NUMERIC(7,2),
    burn_rate_inr            NUMERIC(18,2),
    runway_months            SMALLINT,
    team_size                INT,
    gross_margin_pct         NUMERIC(7,2),
    calculated_at            TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- ============================================================
-- AUDIT LOG (append-only, no updates/deletes)
-- ============================================================
CREATE TABLE audit_log (
    id          BIGSERIAL PRIMARY KEY,
    user_id     UUID REFERENCES users(id) ON DELETE SET NULL,
    action      TEXT NOT NULL,       -- e.g. 'deck.upload', 'analysis.complete', 'deck.delete'
    entity_type TEXT,                -- 'deck', 'analysis', 'readiness', 'valuation'
    entity_id   UUID,
    metadata    JSONB,               -- any extra context
    ip_address  INET,
    user_agent  TEXT,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- ============================================================
-- TRIGGERS: auto-update updated_at
-- ============================================================
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER users_updated_at BEFORE UPDATE ON users
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER startup_profiles_updated_at BEFORE UPDATE ON startup_profiles
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER decks_updated_at BEFORE UPDATE ON decks
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();
```

